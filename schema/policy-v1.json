{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reports.coroboros.com/schema/policy-v1.json",
  "title": "Pruner Policy v1",
  "description": "Org-level policy applied alongside `fail-on`. PLAN.md §10.",
  "type": "object",
  "required": ["version", "name"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "min_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "max_severity": {
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "banned_rules_bypass": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_scans": {
      "type": "array",
      "items": {
        "enum": [
          "cisco",
          "coroboros-pack",
          "gitleaks",
          "actionlint",
          "snyk"
        ]
      }
    },
    "required_attestation": { "type": "boolean" },
    "scan_prompt_defense_posture": { "type": "boolean" },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
